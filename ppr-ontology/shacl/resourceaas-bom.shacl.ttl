@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix aasv: <http://www.w3id.org/aau-ra/resourceaas-validation#> .

# ──────────────────────────────────────────────────────────────────────────────
# HierarchicalStructures (BoM) submodel template constraints
#
# Targets the aasv:HierarchicalStructuresSubmodel marker node created by
# yaml_to_rdf_lite.py, so all constraints are relative to that node.
# ──────────────────────────────────────────────────────────────────────────────

aasv:HierarchicalStructuresSubmodelShape
  a sh:NodeShape ;
  sh:targetClass aasv:HierarchicalStructuresSubmodel ;

  # Name is required — it becomes the BoM root EntryNode idShort and display name.
  sh:property [
    sh:path aasv:bomName ;
    sh:minCount 1 ;
    sh:datatype xsd:string ;
    sh:message "HierarchicalStructures: Name is required (used as the BoM EntryNode identifier)." ;
  ] ;

  # Every projected BoM entity must carry a globalAssetId so it can be a
  # SELF_MANAGED_ENTITY in the generated submodel.
  sh:property [
    sh:path aasv:hasBomEntry ;
    sh:node [
      sh:property [
        sh:path aasv:bomEntryGlobalAssetId ;
        sh:minCount 1 ;
        sh:message "Each BoM entity (IsPartOf / HasPart entry) must have a globalAssetId." ;
      ] ;
    ] ;
  ] ;

  # If an Archetype is set, the corresponding entity list must not be empty.
  sh:sparql [
    a sh:SPARQLConstraint ;
    sh:severity sh:Warning ;
    sh:message "HierarchicalStructures has an Archetype set but no entity entries (IsPartOf/HasPart) are defined yet." ;
    sh:select """
      PREFIX aasv: <http://www.w3id.org/aau-ra/resourceaas-validation#>
      SELECT $this
      WHERE {
        FILTER (
          EXISTS { $this aasv:bomArchetype ?arch . }
          && !EXISTS { $this aasv:hasBomEntry ?entry . }
        )
      }
    """ ;
  ] .
