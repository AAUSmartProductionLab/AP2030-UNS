@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix css: <http://www.w3id.org/hsu-aut/css#> .
@prefix cssx: <http://www.w3id.org/aau-ra/cssx#> .
@prefix cask: <http://www.w3id.org/hsu-aut/cask#> .
@prefix aasv: <http://www.w3id.org/aau-ra/resourceaas-validation#> .

aasv:ResourceAASSemanticShape
  a sh:NodeShape ;
  sh:targetClass css:Resource ;
  sh:targetClass cask:PhysicalResource ;
  sh:targetClass cask:SoftwareResource ;

  sh:property [
    sh:path css:providesCapability ;
    sh:node [
      sh:property [
        sh:path aasv:sourceSemanticId ;
        sh:minCount 1 ;
        sh:message "Each mapped provided capability must include sourceSemanticId and sourceIdShort." ;
      ] ;
      sh:property [
        sh:path aasv:sourceIdShort ;
        sh:minCount 1 ;
        sh:message "Each mapped provided capability must include sourceSemanticId and sourceIdShort." ;
      ] ;
      sh:property [
        sh:path aasv:sourceSemanticId ;
        sh:pattern "^https?://smartproductionlab\\.aau\\.dk/" ;
        sh:message "Each mapped provided capability must include sourceSemanticId and sourceIdShort." ;
      ] ;
    ] ;
  ] ;

  sh:property [
    sh:path css:providesSkill ;
    sh:node [
      sh:property [
        sh:path aasv:sourceSemanticId ;
        sh:minCount 1 ;
        sh:message "Each mapped provided skill must include sourceSemanticId and an accessibleThrough relation." ;
      ] ;
      sh:property [
        sh:path css:accessibleThrough ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "Each mapped provided skill must include sourceSemanticId and an accessibleThrough relation." ;
      ] ;
      sh:property [
        sh:path aasv:sourceSemanticId ;
        sh:pattern "^https?://smartproductionlab\\.aau\\.dk/" ;
        sh:message "Each mapped provided skill must include sourceSemanticId and an accessibleThrough relation." ;
      ] ;
    ] ;
  ] ;

  sh:property [
    sh:path cssx:serialNumber ;
    sh:maxCount 1 ;
    sh:message "serialNumber must not be mapped more than once." ;
  ] ;

  sh:property [
    sh:path cssx:yearOfConstruction ;
    sh:maxCount 1 ;
    sh:pattern "^[0-9]{4}$" ;
    sh:message "yearOfConstruction must be a 4-digit year." ;
  ] ;

  sh:property [
    sh:path cssx:dateOfManufacture ;
    sh:maxCount 1 ;
    sh:pattern "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" ;
    sh:message "dateOfManufacture must follow YYYY-MM-DD." ;
  ] ;

  sh:sparql [
    a sh:SPARQLConstraint ;
    sh:message "If DigitalNameplate is present, serialNumber and manufacturerName must be mapped in CSSx." ;
    sh:select """
      PREFIX aasv: <http://www.w3id.org/aau-ra/resourceaas-validation#>
      PREFIX cssx: <http://www.w3id.org/aau-ra/cssx#>
      SELECT $this
      WHERE {
        FILTER (
          EXISTS {
            $this aasv:hasSubmodel ?sm .
            ?sm a aasv:DigitalNameplateSubmodel .
          }
          && (
            !EXISTS { $this cssx:serialNumber ?serial . }
            || !EXISTS {
              $this cssx:hasManufacturer ?m .
              ?m cssx:manufacturerName ?name .
            }
          )
        )
      }
    """ ;
  ] .
