@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix css: <http://www.w3id.org/hsu-aut/css#> .
@prefix cssx: <http://www.w3id.org/aau-ra/cssx#> .
@prefix cask: <http://www.w3id.org/hsu-aut/cask#> .
@prefix aasv: <http://www.w3id.org/aau-ra/resourceaas-validation#> .

#################################################################
# Manual SPARQL-only constraints
#
# This file is intended to be maintained manually.
# Generated OWL->SHACL baseline constraints are produced separately.
#################################################################

aasv:ResourceAASDependencySparqlShape
  a sh:NodeShape ;
  sh:targetClass css:Resource ;
  sh:targetClass cask:PhysicalResource ;
  sh:targetClass cask:SoftwareResource ;

  sh:sparql [
    a sh:SPARQLConstraint ;
    sh:message "If Skills, OperationalData, or Parameters are present, AID submodel must be present." ;
    sh:select """
      PREFIX css: <http://www.w3id.org/hsu-aut/css#>
      PREFIX cssx: <http://www.w3id.org/aau-ra/cssx#>
      PREFIX aasv: <http://www.w3id.org/aau-ra/resourceaas-validation#>
      SELECT $this
      WHERE {
        FILTER(
          (
            EXISTS { $this css:providesSkill ?skill }
            || EXISTS { $this aasv:hasSubmodel ?skillSm . ?skillSm a aasv:SkillsSubmodel . }
            || EXISTS { $this cssx:hasOperationalData ?opData }
            || EXISTS { $this aasv:hasSubmodel ?opSm . ?opSm a aasv:OperationalDataSubmodel . }
            || EXISTS { $this cssx:hasResourceParameter ?param }
            || EXISTS { $this aasv:hasSubmodel ?paramSm . ?paramSm a aasv:ParametersSubmodel . }
          )
          && !EXISTS {
            $this aasv:hasSubmodel ?aidSm .
            ?aidSm a aasv:AIDSubmodel .
          }
        )
      }
    """ ;
  ] ;

  sh:sparql [
    a sh:SPARQLConstraint ;
    sh:message "If Skills are present, a SoftwareInterface must be present and linked to the skill interface." ;
    sh:select """
      PREFIX css: <http://www.w3id.org/hsu-aut/css#>
      PREFIX cssx: <http://www.w3id.org/aau-ra/cssx#>
      SELECT $this
      WHERE {
        FILTER (
          EXISTS { $this css:providesSkill ?skill }
          && !EXISTS {
            $this cssx:hasResourceInterface ?resourceInterface .
            ?resourceInterface a cssx:SoftwareInterface .
            ?skill css:accessibleThrough ?skillInterface .
            ?skillInterface a css:SkillInterface .
            ?skillInterface cssx:skillInterfaceUsesSoftwareInterface ?resourceInterface .
          }
        )
      }
    """ ;
  ] ;

  sh:sparql [
    a sh:SPARQLConstraint ;
    sh:message "If AID exists, at least one ResourceInterface must be mapped for the Resource." ;
    sh:select """
      PREFIX aasv: <http://www.w3id.org/aau-ra/resourceaas-validation#>
      PREFIX cssx: <http://www.w3id.org/aau-ra/cssx#>
      SELECT $this
      WHERE {
        FILTER (
          EXISTS {
            $this aasv:hasSubmodel ?aidSm .
            ?aidSm a aasv:AIDSubmodel .
          }
          && !EXISTS { $this cssx:hasResourceInterface ?ri . }
        )
      }
    """ ;
  ] ;

  sh:sparql [
    a sh:SPARQLConstraint ;
    sh:message "Each SkillInterface must use a ResourceInterface provided by the same Resource." ;
    sh:select """
      PREFIX css: <http://www.w3id.org/hsu-aut/css#>
      PREFIX cssx: <http://www.w3id.org/aau-ra/cssx#>
      SELECT $this
      WHERE {
        $this css:providesSkill ?skill .
        ?skill css:accessibleThrough ?skillInterface .
        FILTER NOT EXISTS {
          ?skillInterface cssx:skillInterfaceUsesSoftwareInterface ?resourceInterface .
          $this cssx:hasResourceInterface ?resourceInterface .
        }
      }
    """ ;
  ] .

aasv:ResourceAASSemanticSparqlShape
  a sh:NodeShape ;
  sh:targetClass css:Resource ;
  sh:targetClass cask:PhysicalResource ;
  sh:targetClass cask:SoftwareResource ;

  sh:sparql [
    a sh:SPARQLConstraint ;
    sh:message "If DigitalNameplate is present, serialNumber and manufacturerName must be mapped in CSSx." ;
    sh:select """
      PREFIX aasv: <http://www.w3id.org/aau-ra/resourceaas-validation#>
      PREFIX cssx: <http://www.w3id.org/aau-ra/cssx#>
      SELECT $this
      WHERE {
        FILTER (
          EXISTS {
            $this aasv:hasSubmodel ?sm .
            ?sm a aasv:DigitalNameplateSubmodel .
          }
          && (
            !EXISTS { $this cssx:serialNumber ?serial . }
            || !EXISTS {
              $this cssx:hasManufacturer ?m .
              ?m cssx:manufacturerName ?name .
            }
          )
        )
      }
    """ ;
  ] .

aasv:HierarchicalStructuresSparqlShape
  a sh:NodeShape ;
  sh:targetClass aasv:HierarchicalStructuresSubmodel ;

  sh:sparql [
    a sh:SPARQLConstraint ;
    sh:severity sh:Warning ;
    sh:message "HierarchicalStructures has an Archetype set but no entity entries (IsPartOf/HasPart) are defined yet." ;
    sh:select """
      PREFIX aasv: <http://www.w3id.org/aau-ra/resourceaas-validation#>
      SELECT $this
      WHERE {
        FILTER (
          EXISTS { $this aasv:bomArchetype ?arch . }
          && !EXISTS { $this aasv:hasBomEntry ?entry . }
        )
      }
    """ ;
  ] .
