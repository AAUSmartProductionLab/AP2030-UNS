        owl:ObjectProperty ;
    rdfs:domain <http://www.w3id.org/hsu-aut/css#SkillInterface> ;
    rdfs:range [ a rdfs:Resource,
                owl:Class ;
            owl:unionOf [ a rdfs:Resource ;
                    rdf:first <http://www.w3id.org/hsu-aut/css#SkillParameter> ;
                    rdf:rest [ a rdfs:Resource ;
