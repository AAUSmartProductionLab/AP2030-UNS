        <http://www.w3id.org/aau-ra/cssx#TimeSeriesData-hasTimeSeriesMetadata>,
        <http://www.w3id.org/aau-ra/cssx#TimeSeriesData-hasTimeSeriesSegment> .

<http://www.w3id.org/aau-ra/cssx#TimeSeriesSegment> a rdfs:Class,
        rdfs:Resource,
        owl:Class,
        sh:NodeShape ;
    rdfs:comment "Segment of a time-series dataset." ;
    sh:property <http://www.w3id.org/aau-ra/cssx#TimeSeriesSegment-timeSeriesEnd>,
        <http://www.w3id.org/aau-ra/cssx#TimeSeriesSegment-timeSeriesStart>,
        <http://www.w3id.org/aau-ra/cssx#TimeSeriesSegment-timeSeriesValueCount> .

<http://www.w3id.org/aau-ra/resourceaas-validation#BomEntry> a rdfs:Class,
        rdfs:Resource,
        owl:Class,
        sh:NodeShape ;
    rdfs:subClassOf <http://www.w3id.org/aau-ra/resourceaas-validation#ResourceAASProjection> ;
    sh:property <http://www.w3id.org/aau-ra/resourceaas-validation#BomEntry-bomEntryGlobalAssetId>,
        <http://www.w3id.org/aau-ra/resourceaas-validation#BomEntry-bomEntryName> .

<http://www.w3id.org/aau-ra/resourceaas-validation#HierarchicalStructuresSubmodel> a rdfs:Class,
        rdfs:Resource,
        owl:Class,
        sh:NodeShape ;
    rdfs:subClassOf [ a rdfs:Resource,
                owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty <http://www.w3id.org/aau-ra/resourceaas-validation#hasBomEntry> ],
        <http://www.w3id.org/aau-ra/resourceaas-validation#ResourceAASProjection> ;
    sh:property <http://www.w3id.org/aau-ra/resourceaas-validation#HierarchicalStructuresSubmodel-bomArchetype>,
        <http://www.w3id.org/aau-ra/resourceaas-validation#HierarchicalStructuresSubmodel-bomName>,
        <http://www.w3id.org/aau-ra/resourceaas-validation#HierarchicalStructuresSubmodel-hasBomEntry> .

