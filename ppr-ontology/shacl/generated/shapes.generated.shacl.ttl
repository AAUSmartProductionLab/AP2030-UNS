@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://www.w3id.org/aau-ra/cssx#AssetSpecificProperties> a rdfs:Class,
        rdfs:Resource,
        owl:Class,
        sh:NodeShape ;
    rdfs:comment "Collection of asset-specific properties." ;
    sh:property <http://www.w3id.org/aau-ra/cssx#AssetSpecificProperties-hasAssetSpecificProperty> .

<http://www.w3id.org/aau-ra/cssx#BoM> a rdfs:Class,
        rdfs:Resource,
        owl:Class,
        sh:NodeShape ;
    rdfs:comment "Bill of Material as a hierarchy of items." ;
    rdfs:subClassOf _:n2979bea82b7944d5a3300af067f4ca24b2 ;
    sh:property <http://www.w3id.org/aau-ra/cssx#BoM-hasBoMItem> .

<http://www.w3id.org/aau-ra/cssx#BoMItem> a rdfs:Class,
        rdfs:Resource,
        owl:Class,
        sh:NodeShape ;
    rdfs:comment "BoM item describing a component instance or part." ;
    rdfs:subClassOf _:n2979bea82b7944d5a3300af067f4ca24b3 ;
    sh:property <http://www.w3id.org/aau-ra/cssx#BoMItem-hasPart>,
        <http://www.w3id.org/aau-ra/cssx#BoMItem-isPartOf>,
        <http://www.w3id.org/aau-ra/cssx#BoMItem-itemNumber>,
        <http://www.w3id.org/aau-ra/cssx#BoMItem-quantity>,
        <http://www.w3id.org/aau-ra/cssx#BoMItem-quantityUnit> .

<http://www.w3id.org/aau-ra/cssx#CapabilityPortfolio> a rdfs:Class,
        rdfs:Resource,
        owl:Class,
        sh:NodeShape ;
    rdfs:comment "Collection of capability specifications associated with a resource." ;
    sh:property <http://www.w3id.org/aau-ra/cssx#CapabilityPortfolio-portfolioHasCapability> .

<http://www.w3id.org/aau-ra/cssx#CapabilityQualification> a rdfs:Class,
        rdfs:Resource,
        owl:Class,
        sh:NodeShape ;
    rdfs:comment "Qualification and evidence metadata associated with a capability." ;
    sh:property <http://www.w3id.org/aau-ra/cssx#CapabilityQualification-qualificationStatus> .

<http://www.w3id.org/aau-ra/cssx#EndpointMetadata> a rdfs:Class,
        rdfs:Resource,
        owl:Class,
        sh:NodeShape ;
    rdfs:comment "AID endpoint metadata container aligned with WoT Form semantics." ;
    rdfs:subClassOf <https://www.w3.org/2019/wot/td#Form> ;
    sh:property <http://www.w3id.org/aau-ra/cssx#EndpointMetadata-endpointBaseUri>,
        <http://www.w3id.org/aau-ra/cssx#EndpointMetadata-hasSecurityDefinition>,
        <http://www.w3id.org/aau-ra/cssx#EndpointMetadata-interfaceContentType> .

<http://www.w3id.org/aau-ra/cssx#InteractionMetadata> a rdfs:Class,
        rdfs:Resource,
        owl:Class,
        sh:NodeShape ;
    rdfs:comment "Metadata describing interaction affordances of an interface." ;
    sh:property <http://www.w3id.org/aau-ra/cssx#InteractionMetadata-hasInteractionPoint> .

<http://www.w3id.org/aau-ra/cssx#LogicalData> a rdfs:Class,
        rdfs:Resource,
        owl:Class,
        sh:NodeShape ;
    rdfs:comment "Logical operational data such as flags or boolean variables." ;
    rdfs:subClassOf _:n3f0afda306c242f289c94b05ffbe242cb2,
        <http://www.w3id.org/aau-ra/cssx#OperationalData> ;
    sh:property <http://www.w3id.org/aau-ra/cssx#LogicalData-dataReferencesInterface> .

<http://www.w3id.org/aau-ra/cssx#Manufacturer> a rdfs:Class,
        rdfs:Resource,
        owl:Class,
        sh:NodeShape ;
    rdfs:comment "Organization or party responsible for producing a product or resource." ;
    rdfs:subClassOf [ a rdfs:Resource,
                owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty <http://www.w3id.org/aau-ra/cssx#manufacturerName> ] ;
    sh:property <http://www.w3id.org/aau-ra/cssx#Manufacturer-hasAddressInformation>,
        <http://www.w3id.org/aau-ra/cssx#Manufacturer-manufacturerName> .

<http://www.w3id.org/aau-ra/cssx#Markings> a rdfs:Class,
        rdfs:Resource,
        owl:Class,
        sh:NodeShape ;
    rdfs:comment "Set of markings associated with a product or resource." ;
    sh:property <http://www.w3id.org/aau-ra/cssx#Markings-hasMarking> .

<http://www.w3id.org/aau-ra/cssx#MeasuredValue> a rdfs:Class,
        rdfs:Resource,
        owl:Class,
        sh:NodeShape ;
    rdfs:comment "Value object associated with a measurement data point." ;
    sh:property <http://www.w3id.org/aau-ra/cssx#MeasuredValue-measuredNumericValue>,
        <http://www.w3id.org/aau-ra/cssx#MeasuredValue-measuredUnit> .

<http://www.w3id.org/aau-ra/cssx#MeasurementData> a rdfs:Class,
        rdfs:Resource,
        owl:Class,
        sh:NodeShape ;
    rdfs:comment "Measured operational data such as sensor readings." ;
    rdfs:subClassOf [ a rdfs:Resource,
                owl:Restriction ;
            owl:onProperty <http://www.w3id.org/aau-ra/cssx#hasMeasuredValue> ;
            owl:someValuesFrom <http://www.w3id.org/aau-ra/cssx#MeasuredValue> ],
        _:n3f0afda306c242f289c94b05ffbe242cb2,
        <http://www.w3id.org/aau-ra/cssx#OperationalData> ;
    sh:property <http://www.w3id.org/aau-ra/cssx#MeasurementData-dataReferencesInterface>,
        <http://www.w3id.org/aau-ra/cssx#MeasurementData-hasMeasuredValue>,
        <http://www.w3id.org/aau-ra/cssx#MeasurementData-hasMeasurementQualifier>,
        <http://www.w3id.org/aau-ra/cssx#MeasurementData-measurementTimestamp> .

<http://www.w3id.org/aau-ra/cssx#OperationalCapability> a rdfs:Class,
        rdfs:Resource,
        owl:Class,
        sh:NodeShape ;
    rdfs:comment "Capability in plug-and-produce context, expected to be realizable by at least one skill." ;
    rdfs:subClassOf [ a rdfs:Resource,
                owl:Restriction ;
            owl:onProperty <http://www.w3id.org/hsu-aut/css#isRealizedBySkill> ;
            owl:someValuesFrom <http://www.w3id.org/hsu-aut/css#Skill> ],
        _:n1a27d560ed0d4ea491656a1d5c802b1db38,
        _:n1a27d560ed0d4ea491656a1d5c802b1db40,
        <http://www.w3id.org/hsu-aut/css#Capability> ;
    sh:property <http://www.w3id.org/aau-ra/cssx#OperationalCapability-capabilityIdShort>,
        <http://www.w3id.org/aau-ra/cssx#OperationalCapability-capabilityRequiresInterface>,
        <http://www.w3id.org/aau-ra/cssx#OperationalCapability-capabilitySemanticId>,
        <http://www.w3id.org/aau-ra/cssx#OperationalCapability-capabilityUsesOperationalData>,
        <http://www.w3id.org/aau-ra/cssx#OperationalCapability-capabilityUsesResourceParameter>,
        <http://www.w3id.org/aau-ra/cssx#OperationalCapability-hasCapabilityConstraintProfile>,
        <http://www.w3id.org/aau-ra/cssx#OperationalCapability-hasCapabilityQualification>,
        <http://www.w3id.org/aau-ra/cssx#OperationalCapability-isRealizedBySkill>,
        <http://www.w3id.org/aau-ra/cssx#OperationalCapability-sourceSemanticId> .

