@prefix aasv: <http://www.w3id.org/aau-ra/resourceaas-validation#> .
@prefix css: <http://www.w3id.org/hsu-aut/css#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

[] a sh:ValidationReport ;
    sh:conforms false ;
    sh:result [ a sh:ValidationResult ;
            sh:focusNode <https://pharma-example.org/ids/aas/PHARM-DISP-VF-001#capability-dispensingcapability> ;
            sh:resultMessage "Less than 1 values on <https://pharma-example.org/ids/aas/PHARM-DISP-VF-001#capability-dispensingcapability>->aasv:sourceSemanticId" ;
            sh:resultPath aasv:sourceSemanticId ;
            sh:resultSeverity sh:Violation ;
            sh:sourceConstraintComponent sh:MinCountConstraintComponent ;
            sh:sourceShape css:Capability-sourceSemanticId ],
        [ a sh:ValidationResult ;
            sh:focusNode <https://pharma-example.org/ids/aas/PHARM-DISP-VF-001#capability-weighingcapability> ;
            sh:resultMessage "Less than 1 values on <https://pharma-example.org/ids/aas/PHARM-DISP-VF-001#capability-weighingcapability>->aasv:sourceSemanticId" ;
            sh:resultPath aasv:sourceSemanticId ;
            sh:resultSeverity sh:Violation ;
            sh:sourceConstraintComponent sh:MinCountConstraintComponent ;
            sh:sourceShape css:Capability-sourceSemanticId ] .

