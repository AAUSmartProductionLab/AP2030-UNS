@prefix aasv: <http://www.w3id.org/aau-ra/resourceaas-validation#> .
@prefix css: <http://www.w3id.org/hsu-aut/css#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

[] a sh:ValidationReport ;
    sh:conforms false ;
    sh:result [ a sh:ValidationResult ;
            sh:focusNode <https://pharma-example.org/ids/aas/PHARM-DISP-VF-001#skill-weighskill> ;
            sh:resultMessage "Less than 1 values on <https://pharma-example.org/ids/aas/PHARM-DISP-VF-001#skill-weighskill>->aasv:sourceSemanticId" ;
            sh:resultPath aasv:sourceSemanticId ;
            sh:resultSeverity sh:Violation ;
            sh:sourceConstraintComponent sh:MinCountConstraintComponent ;
            sh:sourceShape css:Skill-sourceSemanticId ],
        [ a sh:ValidationResult ;
            sh:focusNode <https://pharma-example.org/ids/aas/PHARM-DISP-VF-001#skill-dispenseskill> ;
            sh:resultMessage "Less than 1 values on <https://pharma-example.org/ids/aas/PHARM-DISP-VF-001#skill-dispenseskill>->aasv:sourceSemanticId" ;
            sh:resultPath aasv:sourceSemanticId ;
            sh:resultSeverity sh:Violation ;
            sh:sourceConstraintComponent sh:MinCountConstraintComponent ;
            sh:sourceShape css:Skill-sourceSemanticId ],
        [ a sh:ValidationResult ;
            sh:focusNode <https://pharma-example.org/ids/aas/PHARM-DISP-VF-001#skill-primeskill> ;
            sh:resultMessage "Less than 1 values on <https://pharma-example.org/ids/aas/PHARM-DISP-VF-001#skill-primeskill>->aasv:sourceSemanticId" ;
            sh:resultPath aasv:sourceSemanticId ;
            sh:resultSeverity sh:Violation ;
            sh:sourceConstraintComponent sh:MinCountConstraintComponent ;
            sh:sourceShape css:Skill-sourceSemanticId ],
        [ a sh:ValidationResult ;
            sh:focusNode <https://pharma-example.org/ids/aas/PHARM-DISP-VF-001#skill-tareskill> ;
            sh:resultMessage "Less than 1 values on <https://pharma-example.org/ids/aas/PHARM-DISP-VF-001#skill-tareskill>->aasv:sourceSemanticId" ;
            sh:resultPath aasv:sourceSemanticId ;
            sh:resultSeverity sh:Violation ;
            sh:sourceConstraintComponent sh:MinCountConstraintComponent ;
            sh:sourceShape css:Skill-sourceSemanticId ] .

