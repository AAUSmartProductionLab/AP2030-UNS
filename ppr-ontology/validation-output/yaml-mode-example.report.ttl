@prefix css: <http://www.w3id.org/hsu-aut/css#> .
@prefix cssx: <http://www.w3id.org/aau-ra/cssx#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

[] a sh:ValidationReport ;
    sh:conforms false ;
    sh:result [ a sh:ValidationResult ;
            sh:focusNode <https://smartproductionlab.aau.dk/aas/imaDispensingSystemAAS> ;
            sh:resultMessage "Value is not Literal with datatype xsd:date" ;
            sh:resultPath cssx:dateOfManufacture ;
            sh:resultSeverity sh:Violation ;
            sh:sourceConstraintComponent sh:DatatypeConstraintComponent ;
            sh:sourceShape css:Resource-dateOfManufacture ;
            sh:value "[VERIFY: manufacture date YYYY-MM-DD]"^^xsd:date ],
        [ a sh:ValidationResult ;
            sh:focusNode <https://smartproductionlab.aau.dk/aas/imaDispensingSystemAAS> ;
            sh:resultMessage "Value is not Literal with datatype rdf:langString" ;
            sh:resultPath cssx:manufacturerProductDesignation ;
            sh:resultSeverity sh:Violation ;
            sh:sourceConstraintComponent sh:DatatypeConstraintComponent ;
            sh:sourceShape css:Resource-manufacturerProductDesignation ;
            sh:value "CA18CLC12BPM1" ] .

