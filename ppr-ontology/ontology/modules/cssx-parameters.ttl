@prefix : <http://www.w3id.org/aau-ra/cssx#> .
@prefix css: <http://www.w3id.org/hsu-aut/css#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

#################################################################
#    Classes
#################################################################

###  http://www.w3id.org/aau-ra/cssx#ResourceParameter
:ResourceParameter rdf:type owl:Class ;
  rdfs:comment "Static configuration parameter of a resource." .

###  http://www.w3id.org/aau-ra/cssx#ParameterGroup
:ParameterGroup rdf:type owl:Class ;
  rdfs:comment "Group of resource parameters." .

###  http://www.w3id.org/aau-ra/cssx#ConfigurationParameter
:ConfigurationParameter rdf:type owl:Class ;
  rdfs:subClassOf :ResourceParameter ;
  rdfs:comment "General configuration parameter of a resource." .

###  http://www.w3id.org/aau-ra/cssx#SpatialParameter
:SpatialParameter rdf:type owl:Class ;
  rdfs:subClassOf :ResourceParameter ;
  rdfs:comment "Spatial configuration parameter such as location or orientation." .

###  http://www.w3id.org/aau-ra/cssx#LocationParameter
:LocationParameter rdf:type owl:Class ;
  rdfs:subClassOf :SpatialParameter ;
  rdfs:comment "Parameter describing a resource location." .

###  http://www.w3id.org/aau-ra/cssx#OrientationParameter
:OrientationParameter rdf:type owl:Class ;
  rdfs:subClassOf :SpatialParameter ;
  rdfs:comment "Parameter describing a resource orientation." .

###  http://www.w3id.org/aau-ra/cssx#CalibrationParameter
:CalibrationParameter rdf:type owl:Class ;
  rdfs:subClassOf :ResourceParameter ;
  rdfs:comment "Parameter describing a calibration or alignment setting." .

###  http://www.w3id.org/aau-ra/cssx#LimitParameter
:LimitParameter rdf:type owl:Class ;
  rdfs:subClassOf :ResourceParameter ;
  rdfs:comment "Parameter defining operational limits or bounds." .

###  http://www.w3id.org/aau-ra/cssx#ParameterScope
:ParameterScope rdf:type owl:Class ;
  rdfs:comment "Scope classification for a resource parameter (e.g., module, line, station)." .

#################################################################
#    Object Properties
#################################################################

###  http://www.w3id.org/aau-ra/cssx#hasResourceParameter
:hasResourceParameter rdf:type owl:ObjectProperty ;
  rdfs:domain css:Resource ;
  rdfs:range :ResourceParameter .

###  http://www.w3id.org/aau-ra/cssx#hasParameterGroup
:hasParameterGroup rdf:type owl:ObjectProperty ;
  rdfs:domain css:Resource ;
  rdfs:range :ParameterGroup .

###  http://www.w3id.org/aau-ra/cssx#groupHasParameter
:groupHasParameter rdf:type owl:ObjectProperty ;
  rdfs:domain :ParameterGroup ;
  rdfs:range :ResourceParameter .

###  http://www.w3id.org/aau-ra/cssx#hasParameterScope
:hasParameterScope rdf:type owl:ObjectProperty ;
  rdfs:domain :ResourceParameter ;
  rdfs:range :ParameterScope .

#################################################################
#    Datatype Properties
#################################################################

###  http://www.w3id.org/aau-ra/cssx#parameterName
:parameterName rdf:type owl:DatatypeProperty ;
  rdfs:domain :ResourceParameter ;
  rdfs:range rdf:langString .

###  http://www.w3id.org/aau-ra/cssx#parameterDescription
:parameterDescription rdf:type owl:DatatypeProperty ;
  rdfs:domain :ResourceParameter ;
  rdfs:range rdf:langString .

###  http://www.w3id.org/aau-ra/cssx#parameterValue
:parameterValue rdf:type owl:DatatypeProperty ;
  rdfs:domain :ResourceParameter ;
  rdfs:range xsd:string .

###  http://www.w3id.org/aau-ra/cssx#parameterValueType
:parameterValueType rdf:type owl:DatatypeProperty ;
  rdfs:domain :ResourceParameter ;
  rdfs:range xsd:string .

###  http://www.w3id.org/aau-ra/cssx#parameterUnit
:parameterUnit rdf:type owl:DatatypeProperty ;
  rdfs:domain :ResourceParameter ;
  rdfs:range xsd:string .

###  http://www.w3id.org/aau-ra/cssx#isReadOnly
:isReadOnly rdf:type owl:DatatypeProperty ;
  rdfs:domain :ResourceParameter ;
  rdfs:range xsd:boolean .

###  http://www.w3id.org/aau-ra/cssx#scopeValue
:scopeValue rdf:type owl:DatatypeProperty ;
  rdfs:domain :ParameterScope ;
  rdfs:range xsd:string .

#################################################################
#    Individuals
#################################################################
