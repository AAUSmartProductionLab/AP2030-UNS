@prefix : <http://www.w3id.org/aau-ra/cssx#> .
@prefix css: <http://www.w3id.org/hsu-aut/css#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

#################################################################
#    Classes
#################################################################

###  http://www.w3id.org/aau-ra/cssx#BoM
:BoM rdf:type owl:Class ;
  rdfs:comment "Bill of Material as a hierarchy of items." .

###  http://www.w3id.org/aau-ra/cssx#ProductBoM
:ProductBoM rdf:type owl:Class ;
  rdfs:subClassOf :BoM ;
  rdfs:comment "BoM describing the product composition." .

###  http://www.w3id.org/aau-ra/cssx#ResourceBoM
:ResourceBoM rdf:type owl:Class ;
  rdfs:subClassOf :BoM ;
  rdfs:comment "BoM describing the resource composition." .

###  http://www.w3id.org/aau-ra/cssx#BoMItem
:BoMItem rdf:type owl:Class ;
  rdfs:comment "BoM item describing a component instance or part." .

###  http://www.w3id.org/aau-ra/cssx#ProductBoMItem
:ProductBoMItem rdf:type owl:Class ;
  rdfs:subClassOf :BoMItem ;
  rdfs:comment "BoM item referencing a product component." .

###  http://www.w3id.org/aau-ra/cssx#ResourceBoMItem
:ResourceBoMItem rdf:type owl:Class ;
  rdfs:subClassOf :BoMItem ;
  rdfs:comment "BoM item referencing a resource component." .

css:Resource rdfs:subClassOf [ rdf:type owl:Restriction ;
  owl:onProperty :hasResourceBoM ;
  owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
  owl:onClass :ResourceBoM
] .

:BoM rdfs:subClassOf [ rdf:type owl:Restriction ;
  owl:onProperty :hasBoMItem ;
  owl:someValuesFrom :BoMItem
] .

:BoMItem rdfs:subClassOf [ rdf:type owl:Restriction ;
  owl:onProperty :itemNumber ;
  owl:minCardinality "1"^^xsd:nonNegativeInteger
] .

#################################################################
#    Object Properties
#################################################################

###  http://www.w3id.org/aau-ra/cssx#hasProductBoM
:hasProductBoM rdf:type owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:domain css:Product ;
  rdfs:range :ProductBoM .

###  http://www.w3id.org/aau-ra/cssx#hasResourceBoM
:hasResourceBoM rdf:type owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:domain css:Resource ;
  rdfs:range :ResourceBoM .

###  http://www.w3id.org/aau-ra/cssx#hasBoMItem
:hasBoMItem rdf:type owl:ObjectProperty ;
  rdfs:domain :BoM ;
  rdfs:range :BoMItem .

###  http://www.w3id.org/aau-ra/cssx#hasPart
:hasPart rdf:type owl:ObjectProperty ;
  rdfs:domain :BoMItem ;
  rdfs:range :BoMItem .

###  http://www.w3id.org/aau-ra/cssx#isPartOf
:isPartOf rdf:type owl:ObjectProperty ;
  rdfs:domain :BoMItem ;
  rdfs:range :BoMItem .

###  http://www.w3id.org/aau-ra/cssx#productBoMItemForProduct
:productBoMItemForProduct rdf:type owl:ObjectProperty ;
  rdfs:domain :ProductBoMItem ;
  rdfs:range css:Product .

###  http://www.w3id.org/aau-ra/cssx#resourceBoMItemForResource
:resourceBoMItemForResource rdf:type owl:ObjectProperty ;
  rdfs:domain :ResourceBoMItem ;
  rdfs:range css:Resource .

#################################################################
#    Datatype Properties
#################################################################

###  http://www.w3id.org/aau-ra/cssx#itemNumber
:itemNumber rdf:type owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:domain :BoMItem ;
  rdfs:range xsd:string .

###  http://www.w3id.org/aau-ra/cssx#quantity
:quantity rdf:type owl:DatatypeProperty ;
  rdfs:domain :BoMItem ;
  rdfs:range xsd:decimal .

###  http://www.w3id.org/aau-ra/cssx#quantityUnit
:quantityUnit rdf:type owl:DatatypeProperty ;
  rdfs:domain :BoMItem ;
  rdfs:range xsd:string .

#################################################################
#    Individuals
#################################################################
