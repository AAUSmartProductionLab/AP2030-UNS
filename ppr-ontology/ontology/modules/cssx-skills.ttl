@prefix : <http://www.w3id.org/aau-ra/cssx#> .
@prefix css: <http://www.w3id.org/hsu-aut/css#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

#################################################################
#    External CSS declarations for VOWL visualization in protege
#################################################################

css:Skill rdf:type owl:Class .
css:SkillInterface rdf:type owl:Class .
css:SkillParameter rdf:type owl:Class .
css:accessibleThrough rdf:type owl:ObjectProperty .

#################################################################
#    Classes
#################################################################

###  http://www.w3id.org/aau-ra/cssx#SkillMode
:SkillMode rdf:type owl:Class ;
  rdfs:comment "Allowed execution mode for a skill (e.g., AUTO, MANUAL)." .

###  http://www.w3id.org/aau-ra/cssx#SkillOperation
:SkillOperation rdf:type owl:Class ;
  rdfs:comment "Abstract operation exposed by a skill." .

###  http://www.w3id.org/aau-ra/cssx#SkillCondition
:SkillCondition rdf:type owl:Class ;
  rdfs:comment "Condition that constrains when a skill operation can be executed." .

###  http://www.w3id.org/aau-ra/cssx#SkillEffect
:SkillEffect rdf:type owl:Class ;
  rdfs:comment "Effect asserted after skill execution." .

###  http://www.w3id.org/aau-ra/cssx#SkillPredicate
:SkillPredicate rdf:type owl:Class ;
  rdfs:comment "Predicate used to express skill executability or logical guards." .

css:Skill rdfs:subClassOf [ rdf:type owl:Restriction ;
  owl:onProperty css:accessibleThrough ;
  owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
  owl:onClass css:SkillInterface
] .

#################################################################
#    Object Properties
#################################################################

###  http://www.w3id.org/aau-ra/cssx#skillInterfaceUsesSoftwareInterface
:skillInterfaceUsesSoftwareInterface rdf:type owl:ObjectProperty ;
  rdfs:domain css:SkillInterface ;
  rdfs:range :SoftwareInterface ;
  rdfs:comment "Skills are invoked through software interfaces." .

###  http://www.w3id.org/aau-ra/cssx#hasSkillMode
:hasSkillMode rdf:type owl:ObjectProperty ;
  rdfs:domain css:Skill ;
  rdfs:range :SkillMode .

###  http://www.w3id.org/aau-ra/cssx#usesSkill
:usesSkill rdf:type owl:ObjectProperty ;
  rdfs:domain css:Skill ;
  rdfs:range css:Skill .

###  http://www.w3id.org/aau-ra/cssx#hasSkillOperation
:hasSkillOperation rdf:type owl:ObjectProperty ;
  rdfs:domain css:Skill ;
  rdfs:range :SkillOperation .

###  http://www.w3id.org/aau-ra/cssx#hasSkillCondition
:hasSkillCondition rdf:type owl:ObjectProperty ;
  rdfs:domain css:Skill ;
  rdfs:range :SkillCondition .

###  http://www.w3id.org/aau-ra/cssx#hasSkillEffect
:hasSkillEffect rdf:type owl:ObjectProperty ;
  rdfs:domain css:Skill ;
  rdfs:range :SkillEffect .

###  http://www.w3id.org/aau-ra/cssx#hasSkillPredicate
:hasSkillPredicate rdf:type owl:ObjectProperty ;
  rdfs:domain css:Skill ;
  rdfs:range :SkillPredicate .

###  http://www.w3id.org/aau-ra/cssx#operationUsesInterface
:operationUsesInterface rdf:type owl:ObjectProperty ;
  rdfs:domain :SkillOperation ;
  rdfs:range :SoftwareInterface .

###  http://www.w3id.org/aau-ra/cssx#operationHasInput
:operationHasInput rdf:type owl:ObjectProperty ;
  rdfs:domain :SkillOperation ;
  rdfs:range css:SkillParameter .

###  http://www.w3id.org/aau-ra/cssx#operationHasOutput
:operationHasOutput rdf:type owl:ObjectProperty ;
  rdfs:domain :SkillOperation ;
  rdfs:range css:SkillParameter .

#################################################################
#    Datatype Properties
#################################################################

###  http://www.w3id.org/aau-ra/cssx#skillModeValue
:skillModeValue rdf:type owl:DatatypeProperty ;
  rdfs:domain :SkillMode ;
  rdfs:range xsd:string .

###  http://www.w3id.org/aau-ra/cssx#operationName
:operationName rdf:type owl:DatatypeProperty ;
  rdfs:domain :SkillOperation ;
  rdfs:range xsd:string .

###  http://www.w3id.org/aau-ra/cssx#operationDescription
:operationDescription rdf:type owl:DatatypeProperty ;
  rdfs:domain :SkillOperation ;
  rdfs:range rdf:langString .

#################################################################
#    Individuals
#################################################################

#################################################################
#    Specific Skill Types (Aseptic Filling Line)
#################################################################

###  http://www.w3id.org/aau-ra/cssx#LoadingSkill
:LoadingSkill rdf:type owl:Class ;
  rdfs:subClassOf css:Skill ;
  rdfs:comment "Skill to load primary containers onto a transport carrier." .

###  http://www.w3id.org/aau-ra/cssx#DispensingSkill
:DispensingSkill rdf:type owl:Class ;
  rdfs:subClassOf css:Skill ;
  rdfs:comment "Skill to dispense bulk product into a primary container." .

###  http://www.w3id.org/aau-ra/cssx#StopperingSkill
:StopperingSkill rdf:type owl:Class ;
  rdfs:subClassOf css:Skill ;
  rdfs:comment "Skill to insert an elastomeric stopper to seal a primary container." .

###  http://www.w3id.org/aau-ra/cssx#CappingSkill
:CappingSkill rdf:type owl:Class ;
  rdfs:subClassOf css:Skill ;
  rdfs:comment "Skill to apply a cap or crimp seal to a primary container." .

###  http://www.w3id.org/aau-ra/cssx#CaptureSkill
:CaptureSkill rdf:type owl:Class ;
  rdfs:subClassOf css:Skill ;
  rdfs:comment "Skill to capture image data for quality control or documentation." .

###  http://www.w3id.org/aau-ra/cssx#QualityControlSkill
:QualityControlSkill rdf:type owl:Class ;
  rdfs:subClassOf css:Skill ;
  rdfs:comment "Skill to perform automated quality inspection." .

###  http://www.w3id.org/aau-ra/cssx#UnloadingSkill
:UnloadingSkill rdf:type owl:Class ;
  rdfs:subClassOf css:Skill ;
  rdfs:comment "Skill to transfer finished product from a transport carrier to output." .

###  http://www.w3id.org/aau-ra/cssx#MoveToPositionSkill
:MoveToPositionSkill rdf:type owl:Class ;
  rdfs:subClassOf css:Skill ;
  rdfs:comment "Skill to move a transport carrier to a target position." .

###  http://www.w3id.org/aau-ra/cssx#ScrapingSkill
:ScrapingSkill rdf:type owl:Class ;
  rdfs:subClassOf css:Skill ;
  rdfs:comment "Skill to remove a defective unit from the production line." .

###  http://www.w3id.org/aau-ra/cssx#HaltSkill
:HaltSkill rdf:type owl:Class ;
  rdfs:subClassOf css:Skill ;
  rdfs:comment "Skill to halt the current operation on a resource." .

###  http://www.w3id.org/aau-ra/cssx#OccupySkill
:OccupySkill rdf:type owl:Class ;
  rdfs:subClassOf css:Skill ;
  rdfs:comment "Skill to occupy a resource for exclusive use." .

###  http://www.w3id.org/aau-ra/cssx#ReleaseSkill
:ReleaseSkill rdf:type owl:Class ;
  rdfs:subClassOf css:Skill ;
  rdfs:comment "Skill to release a resource from exclusive use." .

###  http://www.w3id.org/aau-ra/cssx#ProductionPlanningSkill
:ProductionPlanningSkill rdf:type owl:Class ;
  rdfs:subClassOf css:Skill ;
  rdfs:comment "Skill to generate a production plan from a process AAS." .
