<http://www.w3id.org/aau-ra/cssx> rdf:type owl:Ontology ;
  owl:versionIRI <http://www.w3id.org/aau-ra/cssx/0.1.0> ;
  owl:imports <http://www.w3id.org/hsu-aut/css> ,
              <https://www.w3.org/2019/wot/td> ,
              <./modules/cssx-nameplate.ttl> ,
              <./modules/cssx-bom.ttl> ,
              <./modules/cssx-capabilities.ttl> ,
              <./modules/cssx-skills.ttl> ,
              <./modules/cssx-operational-data.ttl> ,
              <./modules/cssx-parameters.ttl> ,
              <./modules/cssx-resource-interface.ttl> ,
              <./modules/cssx-technical-data.ttl> ,
              <./modules/cssx-aas-validation.ttl> ;
  rdfs:comment "CSS extension ontology for PPR concepts aligned with submodel template needs." .