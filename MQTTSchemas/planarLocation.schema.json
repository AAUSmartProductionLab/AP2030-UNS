{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "Planar Shuttle Location",
    "description": "Periodic location broadcast from a planar shuttle. Carries the raw physical pose (X, Z in mm; Yaw in radians) that the real hardware emits, plus the symbolic location label that the planner/AAS data layer compares against.",
    "type": "object",
    "allOf": [
        {
            "$ref": "https://aausmartproductionlab.github.io/AP2030-UNS/MQTTSchemas/data.schema.json"
        },
        {
            "type": "object",
            "properties": {
                "X": {
                    "type": "number",
                    "description": "X position in mm"
                },
                "Z": {
                    "type": "number",
                    "description": "Z position in mm"
                },
                "Yaw": {
                    "type": "number",
                    "description": "Yaw angle in radians"
                },
                "Location": {
                    "type": "string",
                    "description": "Symbolic location label closest to (X, Z) used by the planner."
                }
            },
            "required": ["X", "Z", "Yaw", "Location"]
        }
    ]
}
