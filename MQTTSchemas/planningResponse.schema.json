{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "Planning Response Schema",
    "description": "Response to a planning command using AI planning and BT policy conversion",
    "type": "object",
    "allOf": [
        {
            "$ref": "https://aausmartproductionlab.github.io/AP2030-UNS/MQTTSchemas/commandResponse.schema.json"
        },
        {
            "type": "object",
            "properties": {
                "ProcessAasId": {
                    "type": "string",
                    "description": "The AAS ID of the generated Process AAS (on success)"
                },
                "ProductAasId": {
                    "type": "string",
                    "description": "The AAS ID of the product that was planned"
                },
                "PlanningSummary": {
                    "type": "object",
                    "description": "Summary of the planner solve mode and status",
                    "properties": {
                        "Mode": {
                            "type": "string",
                            "description": "Planner result mode, e.g. plan or policy"
                        },
                        "Backend": {
                            "type": "string",
                            "description": "Planner backend that produced the result"
                        },
                        "Status": {
                            "type": "string",
                            "description": "Solver status string from the backend"
                        },
                        "WarningsCount": {
                            "type": "integer",
                            "minimum": 0,
                            "description": "Number of planning warnings emitted during solve/export"
                        }
                    }
                },
                "PlanningWarnings": {
                    "type": "array",
                    "description": "Warnings emitted by parsing, solve, or BT conversion",
                    "items": {
                        "type": "string"
                    }
                },
                "PlannedCapabilities": {
                    "type": "array",
                    "description": "Capabilities derived from planner actions for Process AAS generation",
                    "items": {
                        "type": "object",
                        "properties": {
                            "Name": {
                                "type": "string",
                                "description": "Capability name"
                            },
                            "SemanticId": {
                                "type": "string",
                                "description": "Capability semantic ID"
                            },
                            "Resources": {
                                "type": "object",
                                "description": "Mapping from resource name to resource AAS ID",
                                "additionalProperties": {
                                    "type": "string"
                                }
                            }
                        },
                        "required": ["Name", "SemanticId", "Resources"]
                    }
                },
                "PlanningArtifacts": {
                    "type": "object",
                    "description": "Optional artifact paths from the planning pipeline",
                    "additionalProperties": {
                        "type": "string"
                    }
                },
                "ErrorMessage": {
                    "type": "string",
                    "description": "Human-readable error message on failure"
                }
            }
        }
    ]
}
