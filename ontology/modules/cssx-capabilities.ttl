@prefix : <http://www.w3id.org/aau-ra/cssx#> .
@prefix css: <http://www.w3id.org/hsu-aut/css#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

#################################################################
#    External CSS declarations for VOWL visualization in protege
#################################################################

css:Resource rdf:type owl:Class .
css:Capability rdf:type owl:Class .
css:Skill rdf:type owl:Class .
css:Constraint rdf:type owl:Class .

css:providesCapability rdf:type owl:ObjectProperty .
css:providesSkill rdf:type owl:ObjectProperty .
css:isRealizedBySkill rdf:type owl:ObjectProperty .
css:isRestrictedBy rdf:type owl:ObjectProperty .

#################################################################
#    Classes
#################################################################

###  http://www.w3id.org/aau-ra/cssx#OperationalCapability
:OperationalCapability rdf:type owl:Class ;
  rdfs:subClassOf css:Capability ,
    [ rdf:type owl:Restriction ;
      owl:onProperty css:isRealizedBySkill ;
      owl:someValuesFrom css:Skill
    ] ;
  rdfs:comment "Capability in plug-and-produce context, expected to be realizable by at least one skill." .

###  http://www.w3id.org/aau-ra/cssx#CapabilityConstraintProfile
:CapabilityConstraintProfile rdf:type owl:Class ;
  rdfs:subClassOf css:Constraint ;
  rdfs:comment "Constraint profile applied to an operational capability." .

###  http://www.w3id.org/aau-ra/cssx#CapabilityPortfolio
:CapabilityPortfolio rdf:type owl:Class ;
  rdfs:comment "Collection of capability specifications associated with a resource." .

###  http://www.w3id.org/aau-ra/cssx#CapabilityQualification
:CapabilityQualification rdf:type owl:Class ;
  rdfs:comment "Qualification and evidence metadata associated with a capability." .

#################################################################
#    Object Properties
#################################################################

###  http://www.w3id.org/aau-ra/cssx#providesOperationalCapability
:providesOperationalCapability rdf:type owl:ObjectProperty ;
  rdfs:subPropertyOf css:providesCapability ;
  rdfs:domain css:Resource ;
  rdfs:range :OperationalCapability .

###  http://www.w3id.org/aau-ra/cssx#hasCapabilityPortfolio
:hasCapabilityPortfolio rdf:type owl:ObjectProperty ;
  rdfs:domain css:Resource ;
  rdfs:range :CapabilityPortfolio .

###  http://www.w3id.org/aau-ra/cssx#portfolioHasCapability
:portfolioHasCapability rdf:type owl:ObjectProperty ;
  rdfs:domain :CapabilityPortfolio ;
  rdfs:range :OperationalCapability .

###  http://www.w3id.org/aau-ra/cssx#hasCapabilityConstraintProfile
:hasCapabilityConstraintProfile rdf:type owl:ObjectProperty ;
  rdfs:subPropertyOf css:isRestrictedBy ;
  rdfs:domain :OperationalCapability ;
  rdfs:range :CapabilityConstraintProfile .

###  http://www.w3id.org/aau-ra/cssx#capabilityUsesOperationalData
:capabilityUsesOperationalData rdf:type owl:ObjectProperty ;
  rdfs:domain :OperationalCapability ;
  rdfs:range :OperationalData .

###  http://www.w3id.org/aau-ra/cssx#capabilityUsesResourceParameter
:capabilityUsesResourceParameter rdf:type owl:ObjectProperty ;
  rdfs:domain :OperationalCapability ;
  rdfs:range :ResourceParameter .

###  http://www.w3id.org/aau-ra/cssx#capabilityRequiresInterface
:capabilityRequiresInterface rdf:type owl:ObjectProperty ;
  rdfs:domain :OperationalCapability ;
  rdfs:range :ResourceInterface .

###  http://www.w3id.org/aau-ra/cssx#hasCapabilityQualification
:hasCapabilityQualification rdf:type owl:ObjectProperty ;
  rdfs:domain :OperationalCapability ;
  rdfs:range :CapabilityQualification .

#################################################################
#    Datatype Properties
#################################################################

###  http://www.w3id.org/aau-ra/cssx#capabilitySemanticId
:capabilitySemanticId rdf:type owl:DatatypeProperty ;
  rdfs:domain :OperationalCapability ;
  rdfs:range xsd:anyURI .

###  http://www.w3id.org/aau-ra/cssx#capabilityIdShort
:capabilityIdShort rdf:type owl:DatatypeProperty ;
  rdfs:domain :OperationalCapability ;
  rdfs:range xsd:string .

###  http://www.w3id.org/aau-ra/cssx#qualificationStatus
:qualificationStatus rdf:type owl:DatatypeProperty ;
  rdfs:domain :CapabilityQualification ;
  rdfs:range xsd:string .

#################################################################
#    SHACL-aligned OWL constraints
#################################################################

[ rdf:type owl:Class ;
  owl:intersectionOf (
    css:Resource
    [ rdf:type owl:Restriction ;
      owl:onProperty css:providesSkill ;
      owl:someValuesFrom css:Skill
    ]
  )
] rdfs:subClassOf [
  rdf:type owl:Restriction ;
  owl:onProperty css:providesCapability ;
  owl:someValuesFrom css:Capability
] .

[ rdf:type owl:Class ;
  owl:intersectionOf (
    css:Resource
    [ rdf:type owl:Restriction ;
      owl:onProperty css:providesCapability ;
      owl:someValuesFrom css:Capability
    ]
  )
] rdfs:subClassOf [
  rdf:type owl:Restriction ;
  owl:onProperty css:providesSkill ;
  owl:someValuesFrom css:Skill
] .
